				["at1020"] = <
					text = <"الساعد الأيمن">
					description = <"الساعد الأيمن للشخص">
				>
				["at1021"] = <
					text = <"الساعد الأيسر">
					description = <"الساعد الأيسر للشخص">
				>
				["at1025"] = <
					text = <"الجهيزة">
