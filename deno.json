{
  "nodeModulesDir": "auto",
  "imports": {
    "@lezer/highlight": "npm:@lezer/highlight@^1.2.1",
    "@codemirror/commands": "npm:@codemirror/commands@^6.8.1",
    "@codemirror/lang-javascript": "npm:@codemirror/lang-javascript@^6.2.4",
    "@codemirror/lang-json": "npm:@codemirror/lang-json@^6.0.2",
    "@codemirror/lang-xml": "npm:@codemirror/lang-xml@^6.1.0",
    "@codemirror/lang-yaml": "npm:@codemirror/lang-yaml@^6.1.2",
    "@codemirror/language": "npm:@codemirror/language@^6.11.3",
    "@codemirror/state": "npm:@codemirror/state@^6.5.2",
    "@codemirror/view": "npm:@codemirror/view@^6.38.0",
    "fast-xml-parser": "npm:fast-xml-parser@^4.3.0",
    "yaml": "npm:yaml@^2.3.4",
    "fflate": "npm:fflate@^0.8.2",
    "d3": "npm:d3@7.9.0"
  },
  "tasks": {
    "test": "deno test --allow-read",
    "check": "deno check enhanced/*.ts",
    "generate:rm-meta": "deno run --allow-read --allow-net --allow-write tasks/generate_rm_meta.ts",
    "generate:symbol-table": "deno run --allow-read --allow-write enhanced/serialization/zipehr/gen_symbol_table.ts",
    "build:demo": "deno run -A examples/demo-app/scripts/build.ts",
    "dev:demo": "deno run -A examples/demo-app/scripts/dev-server.ts",
    "build:taaat": "deno run -A examples/taaat-app/scripts/build.ts"
  }
}